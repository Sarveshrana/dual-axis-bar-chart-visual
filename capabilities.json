{
  "privileges": [],
  "dataRoles": [
    {
      "name": "category",
      "displayName": "Category",
      "kind": "Grouping"
    },
    {
      "name": "primaryValue",
      "displayName": "Primary Value",
      "kind": "Measure"
    },
    {
      "name": "secondaryValue",
      "displayName": "Secondary Value",
      "kind": "Measure"
    }
  ],
  "dataViewMappings": [
    {
      "categorical": {
        "categories": {
          "for": { "in": "category" },
          "dataReductionAlgorithm": { "top": {} }
        },
        "values": {
          "select": [
            { "bind": { "to": "primaryValue"   } },
            { "bind": { "to": "secondaryValue" } }
          ]
        }
      }
    }
  ],
  "objects": {
    "barColors": {
      "displayName": "Bar Styling",
      "properties": {
        "primaryBarColor": {
          "displayName": "Primary Bar Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "secondaryBarColor": {
          "displayName": "Secondary Bar Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "barOpacity":      { "displayName": "Bar Opacity (%)",   "type": { "numeric": true } },
        "barCornerRadius": { "displayName": "Corner Radius (px)", "type": { "numeric": true } },
        "enableNegativeColors": { "displayName": "Different Color for Negative Values", "type": { "bool": true } },
        "primaryBarNegColor": {
          "displayName": "Primary — Negative Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "secondaryBarNegColor": {
          "displayName": "Secondary — Negative Color",
          "type": { "fill": { "solid": { "color": true } } }
        }
      }
    },
    "legend": {
      "displayName": "Legend",
      "properties": {
        "showLegend":           { "displayName": "Show Legend",           "type": { "bool": true } },
        "legendPrimaryLabel":   { "displayName": "Primary Series Name",   "type": { "text": true } },
        "legendSecondaryLabel": { "displayName": "Secondary Series Name", "type": { "text": true } },
        "legendPosition": {
          "displayName": "Position",
          "type": { "enumeration": [
            { "value": "top",    "displayName": "Top"    },
            { "value": "bottom", "displayName": "Bottom" }
          ]}
        },
        "legendFontSize": { "displayName": "Font Size", "type": { "numeric": true } }
      }
    },
    "xAxis": {
      "displayName": "X-Axis",
      "properties": {
        "showXAxis":   { "displayName": "Show X-Axis", "type": { "bool": true } },
        "xAxisTitle":  { "displayName": "Axis Title",  "type": { "text": true } },
        "xAxisFontSize": { "displayName": "Font Size", "type": { "numeric": true } },
        "xAxisLabelRotation": {
          "displayName": "Label Rotation",
          "type": { "enumeration": [
            { "value": "0",   "displayName": "0°"   },
            { "value": "-30", "displayName": "-30°" },
            { "value": "-45", "displayName": "-45°" },
            { "value": "-90", "displayName": "-90°" }
          ]}
        },
        "xAxisMaxLabelLength": { "displayName": "Max Label Length (0 = off)", "type": { "numeric": true } }
      }
    },
    "leftAxis": {
      "displayName": "Left Y-Axis (Primary)",
      "properties": {
        "showLeftAxis":  { "displayName": "Show Left Y-Axis", "type": { "bool": true } },
        "leftAxisTitle": { "displayName": "Axis Title",       "type": { "text": true } },
        "leftAxisFontSize": { "displayName": "Font Size",     "type": { "numeric": true } },
        "leftAxisDisplayUnits": {
          "displayName": "Display Units",
          "type": { "enumeration": [
            { "value": "auto",      "displayName": "Auto"          },
            { "value": "none",      "displayName": "None"          },
            { "value": "thousands", "displayName": "Thousands (K)" },
            { "value": "millions",  "displayName": "Millions (M)"  },
            { "value": "billions",  "displayName": "Billions (B)"  }
          ]}
        },
        "leftAxisAutoRange": { "displayName": "Auto Range",         "type": { "bool": true }    },
        "leftAxisMin":       { "displayName": "Min Value (manual)", "type": { "numeric": true } },
        "leftAxisMax":       { "displayName": "Max Value (manual)", "type": { "numeric": true } }
      }
    },
    "rightAxis": {
      "displayName": "Right Y-Axis (Secondary)",
      "properties": {
        "showRightAxis":  { "displayName": "Show Right Y-Axis", "type": { "bool": true } },
        "rightAxisTitle": { "displayName": "Axis Title",        "type": { "text": true } },
        "rightAxisFontSize": { "displayName": "Font Size",      "type": { "numeric": true } },
        "rightAxisDisplayUnits": {
          "displayName": "Display Units",
          "type": { "enumeration": [
            { "value": "auto",      "displayName": "Auto"          },
            { "value": "none",      "displayName": "None"          },
            { "value": "thousands", "displayName": "Thousands (K)" },
            { "value": "millions",  "displayName": "Millions (M)"  },
            { "value": "billions",  "displayName": "Billions (B)"  }
          ]}
        },
        "rightAxisAutoRange": { "displayName": "Auto Range",         "type": { "bool": true }    },
        "rightAxisMin":       { "displayName": "Min Value (manual)", "type": { "numeric": true } },
        "rightAxisMax":       { "displayName": "Max Value (manual)", "type": { "numeric": true } }
      }
    },
    "gridLines": {
      "displayName": "Grid Lines",
      "properties": {
        "showGridLines": { "displayName": "Show Grid Lines", "type": { "bool": true } },
        "gridLineColor": {
          "displayName": "Grid Line Color",
          "type": { "fill": { "solid": { "color": true } } }
        }
      }
    },
    "dataLabels": {
      "displayName": "Data Labels",
      "properties": {
        "showDataLabels":     { "displayName": "Show Data Labels",     "type": { "bool": true }                          },
        "dataLabelsFontSize": { "displayName": "Font Size",            "type": { "numeric": true }                       },
        "dataLabelsPrimaryColor": {
          "displayName": "Primary Label Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "dataLabelsSecondaryColor": {
          "displayName": "Secondary Label Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "dataLabelsDisplayUnits": {
          "displayName": "Display Units",
          "type": { "enumeration": [
            { "value": "auto",      "displayName": "Auto"          },
            { "value": "none",      "displayName": "None"          },
            { "value": "thousands", "displayName": "Thousands (K)" },
            { "value": "millions",  "displayName": "Millions (M)"  },
            { "value": "billions",  "displayName": "Billions (B)"  }
          ]}
        }
      }
    }
  },
  "tooltips": {
    "supportedTypes": { "default": true, "canvas": true },
    "roles": ["tooltips"]
  }
}
